Name: python3-rawstor
Version: @PACKAGE_VERSION_SHORT@
Release: @RPM_RELEASE@
Summary: Rawstor python bindings

License: LGPL
URL: https://github.com/rawstor/librawstor
Source0: librawstor-@PACKAGE_VERSION@.tar.gz

%description
Rawstor python bindings

%prep
%autosetup -n librawstor-@PACKAGE_VERSION@

%build
./configure --prefix=%{_prefix}
make %{?_smp_mflags}

%install
rm -rf %{buildroot}
make -C pyrawstor install DESTDIR=%{buildroot}
echo ====
ls -lhR %{buildroot}
echo ====

%files
%{python3_sitearch}/*
