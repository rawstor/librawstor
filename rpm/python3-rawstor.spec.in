Name: python3-rawstor
Version: @PACKAGE_VERSION_SHORT@
Release: @RPM_RELEASE@
Summary: Rawstor python bindings

License: LGPL
URL: https://github.com/rawstor/librawstor
Source0: %{name}-@PACKAGE_VERSION@.tar.gz

%description
Rawstor python bindings

%prep
%autosetup -n %{name}-@PACKAGE_VERSION@

%build
./configure --prefix=%{_prefix}
make %{?_smp_mflags}

%install
rm -rf %{buildroot}
make -C pyrawstor install DESTDIR=%{buildroot}

%files
%{_bindir}/*
%{_includedir}/*
%{_exec_prefix}/lib*/*
%doc README.md COPYING
