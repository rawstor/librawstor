#ifndef RAWSTD_CONFIG_H
#define RAWSTD_CONFIG_H

#define RAWSTD_LOGLEVEL_NONE 0
#define RAWSTD_LOGLEVEL_ERROR 1
#define RAWSTD_LOGLEVEL_WARNING 2
#define RAWSTD_LOGLEVEL_INFO 3
#define RAWSTD_LOGLEVEL_DEBUG 4
#define RAWSTD_LOGLEVEL_TRACE 5

@maybe_loglevel_define@

#if !defined(RAWSTD_LOGLEVEL)
#define RAWSTD_LOGLEVEL RAWSTD_LOGLEVEL_INFO
#endif

#endif // RAWSTD_CONFIG_H
